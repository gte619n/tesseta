<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only manifest overlay. Merges into the main manifest for debug builds
  only and wires up the debug network security config (cleartext to the local
  dev backend). Release builds never see this.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
