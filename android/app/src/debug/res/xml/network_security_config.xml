<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only network security config. Permits cleartext (HTTP) traffic to the
  local dev backend so debug builds can talk to `bash infra/scripts/dev.sh`
  running on the host (10.0.2.2 is the emulator's route to host localhost).
  This file lives in src/debug, so release builds are unaffected and keep the
  platform default of HTTPS-only.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
