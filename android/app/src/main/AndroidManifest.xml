<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- IMPL-13: nutrition Capture screen (barcode scan + meal/label photos). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <!-- Health Connect permission placeholders. Each capability becomes a separate
         android.permission.health.READ_*/WRITE_* line when wired in (IMPL-XX).
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    -->

    <!-- ADR-0012 D6: WorkoutSessionService, foregroundServiceType="health".
         API 34+ additionally gates the health type on the app either declaring
         HIGH_SAMPLING_RATE_SENSORS or holding the ACTIVITY_RECOGNITION /
         BODY_SENSORS runtime grant; HIGH_SAMPLING_RATE_SENSORS is a normal
         install-time permission, so it satisfies the gate without prompting
         the user for sensor access the manual logger doesn't use. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />

    <!-- API 33+ runtime permission for the session notification in the shade.
         The foreground service runs (and the FGS Task-Manager entry shows)
         without the grant; the logger UI requests it when starting a session. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- IMPL-COACH: haptic buzz when a rest period ends (WorkoutSessionService). -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- IMPL-COACH PR2: the coach speaks set cues via TextToSpeech; API 30+
         package visibility requires declaring the TTS engine intent. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:name=".HealthFitnessApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:enableOnBackInvokedCallback="true"
        android:supportsRtl="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:theme="@style/Theme.HealthFitness">

        <!-- IMPL-13: ML Kit barcode + OCR run on the *unbundled* (play-services)
             variants, so the model native libs/.tflite are kept out of the APK
             and downloaded via Play Services. This meta-data asks Play Services
             to fetch both models at install time, so the first nutrition scan
             isn't a no-op while the model downloads. -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode,ocr" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop"
            android:resizeableActivity="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|density|keyboardHidden|keyboard|navigation|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- IMPL-STAB Workstream F (item 4): medication reminder notifications
                 deep-link to the dose checklist (healthfitness://medications/today)
                 instead of opening app home. Matched by the medications LIST
                 destination's navDeepLink in AppNavHost. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="healthfitness" android:host="medications" />
            </intent-filter>
            <!-- The ongoing-workout notification deep-links back into the active
                 session logger (healthfitness://workout-session/{programId}/{scheduledId}).
                 Matched by the SESSION destination's navDeepLink in WorkoutsRoutes. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="healthfitness" android:host="workout-session" />
            </intent-filter>
        </activity>

        <!-- IMPL-02: handles /auth/refresh-request messages from the paired
             wear device by running a silent Credential Manager refresh. -->
        <service
            android:name=".wear.PhoneRefreshRequestService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/auth/" />
            </intent-filter>
        </service>

        <!-- IMPL-AND-20 (Phase 4): disable WorkManager's default initializer so
             the Hilt worker factory (HealthFitnessApp implements
             Configuration.Provider) supplies dependencies to the @HiltWorker sync
             workers. Removing this node lets WorkManager auto-init without Hilt. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- IMPL-AND-20 (Phase 6): FCM client. Receives silent data-only
             {type:sync} messages and enqueues an expedited WorkManager pull.
             Not exported; the framework delivers MESSAGING_EVENT internally. -->
        <service
            android:name=".push.HfMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- IMPL-AND-04 / IMPL-AND-05: share downloaded lab/DEXA PDFs with the
             system viewer via ACTION_VIEW over a content:// URI. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- ADR-0012 D6 (IMPL-AND-17): foreground service for active workout
             sessions — owns the ongoing timer notification while a local draft
             exists; stops itself when the draft is finished/skipped/discarded. -->
        <service
            android:name=".workouts.WorkoutSessionService"
            android:foregroundServiceType="health"
            android:exported="false" />
    </application>
</manifest>
